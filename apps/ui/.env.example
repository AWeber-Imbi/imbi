# API Base URL - use /api for local proxy, or full URL for direct connection
VITE_API_URL=/api

# API Token for development (get from https://imbi.aweber.io/ui/user/tokens)
VITE_API_TOKEN=

# Proxy targets (used by Vite dev server)
IMBI_API_URL=https://imbi.aweber.io
IMBI_ASSISTANT_URL=http://127.0.0.1:8002
IMBI_GATEWAY_URL=http://127.0.0.1:8003
