{
  "name": "imbi-ui-v2",
  "version": "2.4.2",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "codegen": "openapi-typescript openapi.json -o src/types/api-generated.ts",
    "codegen:fetch": "curl -sf http://localhost:8000/openapi.json -o openapi.json && npm run codegen",
    "dev": "vite",
    "format": "oxfmt 'src/**/*.{ts,tsx,css}' 'tools/**/*.ts' package.json '*.config.{js,ts}'",
    "format:check": "oxfmt --check 'src/**/*.{ts,tsx,css}' 'tools/**/*.ts' package.json '*.config.{js,ts}'",
    "lint": "oxlint .",
    "lint:fallow": "fallow dead-code",
    "lint:fix": "oxlint --fix .",
    "prepare": "husky",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@icons-pack/react-simple-icons": "^13.11.2",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-alert-dialog": "^1.1.4",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-hover-card": "^1.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@sentry/react": "^10.53.1",
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-query": "^5.66.1",
    "@tanstack/react-virtual": "^3.13.24",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "aws-svg-icons": "^3.0.0-2021-07-30",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "devicon": "^2.17.0",
    "js-yaml": "^4.1.1",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.469.0",
    "match-sorter": "^8.3.0",
    "md5": "^2.3.0",
    "react": "^19.2.4",
    "react-day-picker": "^9.4.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^9.0.3",
    "react-resizable-panels": "^4.11.1",
    "react-router-dom": "^7.1.1",
    "reagraph": "^4.30.8",
    "remark-gfm": "^4.0.0",
    "sonner": "^1.7.2",
    "spark-md5": "^3.0.2",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@oxlint/plugins": "^1.64.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/md5": "^2.3.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/spark-md5": "^3.0.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4.0.16",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fallow": "^2.67.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.4.0",
    "openapi-typescript": "^7.13.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tailwindcss": "^0.7.1",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.0.16"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --fix --no-error-on-unmatched-pattern",
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*.css": [
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*.config.{js,ts}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "package.json": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  }
}
