# Shared dev image for every Python service in the Okteto environment.
# The whole repo is copied in and synced over by `okteto up`; each
# compose.dev.yaml service differs only in the command it runs.
FROM python:3.14-slim

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

RUN apt-get update \
 && apt-get install -y --no-install-recommends bash build-essential git \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
COPY ./ /workspace
RUN uv sync --all-groups --all-extras
