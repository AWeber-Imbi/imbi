#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = [
#     "rich~=13.0",
#     "typer~=0.21.0",
# ]
# ///
"""Manage Caddy reverse_proxy upstreams for Imbi services.

Tag upstreams with @id for named access, then switch traffic
between Docker Compose services and localhost.

Usage:
    ./manage-caddy list
    ./manage-caddy annotate
    ./manage-caddy up imbi-api
    ./manage-caddy down imbi-api
    ./manage-caddy list --caddy-url http://127.0.0.1:2019

By default, the Caddy admin URL is read from
runtime/state/caddy-url (relative to this script). Use
--caddy-url to override or --caddy-url-file to point elsewhere.

Exit codes:
    0: Success
    1: Partial failure (some operations failed)
    2: Fatal error (cannot reach Caddy API)
"""

import contextlib
import http.client
import json
import pathlib
import typing as t
import urllib.parse

import rich.console
import rich.table
import typer

console = rich.console.Console()

DEFAULT_CADDY_FILE = (
    pathlib.Path(__file__).resolve().parent / 'state' / 'caddy-url'
)


def resolve_caddy_url(
    caddy_url: str | None,
    caddy_url_file: pathlib.Path,
) -> str:
    """Resolve the Caddy admin API URL from option or file."""
    if caddy_url is not None:
        return caddy_url
    try:
        url = caddy_url_file.read_text().strip()
        if url:
            return url
    except FileNotFoundError:
        pass
    console.print(
        '[bold red]Error:[/bold red] No --caddy-url given and '
        f'{caddy_url_file} not found'
    )
    raise typer.Exit(2)


app = typer.Typer(
    help='Manage Caddy reverse_proxy upstreams for Imbi services',
    add_completion=False,
)


class CaddyAPIError(Exception):
    """Raised when a Caddy admin API request fails."""

    def __init__(
        self,
        message: str,
        status_code: int | None = None,
    ) -> None:
        super().__init__(message)
        self.status_code = status_code


def api_request(admin_url, path, method='GET', body=None):
    """Send a request to the Caddy admin API."""
    parsed = urllib.parse.urlparse(admin_url)
    with contextlib.closing(
        http.client.HTTPConnection(parsed.hostname, parsed.port, timeout=5)
    ) as conn:
        headers = {}
        if body is not None:
            headers['Content-Type'] = 'application/json'
        conn.request(method, path, body=body, headers=headers)
        resp = conn.getresponse()
        data = resp.read()
        if resp.status >= 400:
            raise CaddyAPIError(
                f'{method} {path} returned {resp.status}: {data}',
                status_code=resp.status,
            )

    return json.loads(data) if data else None


def find_upstreams(routes):
    """Yield (service_name, route_index, sub_route_index)
    for each route with a strip_path_prefix rewrite and a
    reverse_proxy upstream."""
    for route_idx, route in enumerate(routes):
        for handler in route.get('handle', []):
            if handler.get('handler') != 'subroute':
                continue
            prefix = None
            upstream_sub_idx = None
            for sub_idx, sub_route in enumerate(handler['routes']):
                for sub_handler in sub_route.get('handle', []):
                    if (
                        sub_handler.get('handler') == 'rewrite'
                        and 'strip_path_prefix' in sub_handler
                    ):
                        prefix = sub_handler[
                            'strip_path_prefix'
                        ].lstrip('/')
                    if (
                        sub_handler.get('handler')
                        == 'reverse_proxy'
                        and sub_handler.get('upstreams')
                    ):
                        upstream_sub_idx = sub_idx
            if prefix and upstream_sub_idx is not None:
                yield f'imbi-{prefix}', route_idx, upstream_sub_idx


@app.command(name='list')
def list_upstreams(
    caddy_url: t.Annotated[
        str | None,
        typer.Option(help='Caddy admin API URL'),
    ] = None,
    caddy_url_file: t.Annotated[
        pathlib.Path,
        typer.Option(
            help='File containing the Caddy admin API URL',
        ),
    ] = DEFAULT_CADDY_FILE,
) -> None:
    """Show current upstream targets for all services."""
    url = resolve_caddy_url(caddy_url, caddy_url_file)
    routes_path = '/config/apps/http/servers/srv0/routes'

    try:
        routes = api_request(url, routes_path)
    except CaddyAPIError as exc:
        console.print(
            f'[bold red]Error:[/bold red] {exc}'
        )
        raise typer.Exit(2) from exc

    table = rich.table.Table(title='Service Upstreams')
    table.add_column('Service', style='cyan')
    table.add_column('Dial', style='white')
    table.add_column('Status', style='white')

    for name, route_idx, sub_route_idx in find_upstreams(routes):
        upstream_path = (
            f'{routes_path}/{route_idx}'
            f'/handle/0/routes/{sub_route_idx}'
            f'/handle/0/upstreams/0'
        )
        try:
            upstream = api_request(url, upstream_path)
            dial = upstream['dial']
            if dial.startswith('127.0.0.1:'):
                status = '[yellow]down[/yellow]'
            else:
                status = '[green]up[/green]'
            table.add_row(name, dial, status)
        except CaddyAPIError as exc:
            table.add_row(
                name, '?', f'[red]error: {exc}[/red]'
            )

    console.print(table)


@app.command()
def annotate(
    caddy_url: t.Annotated[
        str | None,
        typer.Option(help='Caddy admin API URL'),
    ] = None,
    caddy_url_file: t.Annotated[
        pathlib.Path,
        typer.Option(
            help='File containing the Caddy admin API URL',
        ),
    ] = DEFAULT_CADDY_FILE,
) -> None:
    """Tag each reverse_proxy upstream with an @id."""
    url = resolve_caddy_url(caddy_url, caddy_url_file)
    routes_path = '/config/apps/http/servers/srv0/routes'

    try:
        routes = api_request(url, routes_path)
    except CaddyAPIError as exc:
        console.print(
            f'[bold red]Error:[/bold red] {exc}'
        )
        raise typer.Exit(2) from exc

    table = rich.table.Table(title='Annotated Upstreams')
    table.add_column('Service', style='cyan')
    table.add_column('Dial', style='white')
    table.add_column('ID Path', style='dim')

    failures = 0
    for name, route_idx, sub_route_idx in find_upstreams(routes):
        upstream_path = (
            f'{routes_path}/{route_idx}'
            f'/handle/0/routes/{sub_route_idx}'
            f'/handle/0/upstreams/0'
        )
        try:
            upstream = api_request(url, upstream_path)
            upstream['@id'] = name
            api_request(
                url,
                upstream_path,
                method='PATCH',
                body=json.dumps(upstream),
            )
            table.add_row(
                name, upstream['dial'], f'/id/{name}'
            )
        except CaddyAPIError as exc:
            console.print(
                f'[bold red]Error tagging {name}:[/bold red] {exc}'
            )
            failures += 1

    console.print(table)

    if failures:
        raise typer.Exit(1)


@app.command()
def up(
    service: t.Annotated[
        str,
        typer.Argument(help='Service name (e.g. imbi-api)'),
    ],
    caddy_url: t.Annotated[
        str | None,
        typer.Option(help='Caddy admin API URL'),
    ] = None,
    caddy_url_file: t.Annotated[
        pathlib.Path,
        typer.Option(
            help='File containing the Caddy admin API URL',
        ),
    ] = DEFAULT_CADDY_FILE,
) -> None:
    """Route traffic to the Docker Compose service."""
    url = resolve_caddy_url(caddy_url, caddy_url_file)
    try:
        upstream = api_request(url, f'/id/{service}')
    except CaddyAPIError as exc:
        console.print(
            f'[bold red]Error:[/bold red] {exc}'
        )
        raise typer.Exit(2) from exc

    old_dial = upstream['dial']
    port = old_dial.rsplit(':', 1)[1]
    new_dial = f'{service}:{port}'

    try:
        api_request(
            url,
            f'/id/{service}',
            method='PATCH',
            body=json.dumps({'@id': service, 'dial': new_dial}),
        )
    except CaddyAPIError as exc:
        console.print(
            f'[bold red]Error:[/bold red] {exc}'
        )
        raise typer.Exit(2) from exc

    console.print(
        f'[green]{service}:[/green] {old_dial} -> {new_dial}'
    )


@app.command()
def down(
    service: t.Annotated[
        str,
        typer.Argument(help='Service name (e.g. imbi-api)'),
    ],
    caddy_url: t.Annotated[
        str | None,
        typer.Option(help='Caddy admin API URL'),
    ] = None,
    caddy_url_file: t.Annotated[
        pathlib.Path,
        typer.Option(
            help='File containing the Caddy admin API URL',
        ),
    ] = DEFAULT_CADDY_FILE,
) -> None:
    """Route traffic to localhost (disable service)."""
    url = resolve_caddy_url(caddy_url, caddy_url_file)
    try:
        upstream = api_request(url, f'/id/{service}')
    except CaddyAPIError as exc:
        console.print(
            f'[bold red]Error:[/bold red] {exc}'
        )
        raise typer.Exit(2) from exc

    old_dial = upstream['dial']
    port = old_dial.rsplit(':', 1)[1]
    new_dial = f'127.0.0.1:{port}'

    try:
        api_request(
            url,
            f'/id/{service}',
            method='PATCH',
            body=json.dumps({'@id': service, 'dial': new_dial}),
        )
    except CaddyAPIError as exc:
        console.print(
            f'[bold red]Error:[/bold red] {exc}'
        )
        raise typer.Exit(2) from exc

    console.print(
        f'[yellow]{service}:[/yellow] {old_dial} -> {new_dial}'
    )


if __name__ == '__main__':
    app()
